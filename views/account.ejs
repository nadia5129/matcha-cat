<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Account' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>

<body>
  <header class="site-header">
    <img src="/images/logo.jpg" alt="Matcha Cat Cafe Logo">
  </header>

  <main class="account-page">
    <!-- Profile Card -->
    <section class="profile-hero card">
      <div class="profile-copy">
        <p class="eyebrow">My Account</p>
        <h1>Hi, User</h1>
        <p>Manage your profile, check past orders, and keep track of your reservations.</p>
      </div>
    </section>

    <!-- Edit Profile Card-->
    <section class="user-form card">
      <div class="section-heading">
        <p class="eyebrow">Profile</p>
        <h2>Edit Information</h2>
      </div>

      <form action="/edit-profile" method="POST" class="account-form">
        <div class="form-field">
          <label for="fname">First Name</label>
          <input type="text" id="fname" name="fname" placeholder="Enter your first name" required>
        </div>

        <div class="form-field">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 555-5555" required>
        </div>

        <div class="form-field full-width">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="Enter your email" required>
        </div>

        <button type="submit" class="btn btn-primary full-width">Save Changes</button>
      </form>
    </section>

    <!-- Past Orders Card-->
    <section class="account-panel card ">
      <div class="section-heading">
        <p class="eyebrow">Orders</p>
        <h2>Past Orders</h2>
      </div>

      <div class="empty-state">
        <p>Your previous drinks and treats will show up here.</p>
        <a href="/menu" class="btn btn-secondary">Order Something Sweet</a>
      </div>
    </section>

    <!-- Past Reservations Card-->
    <section class="account-panel card ">
      <div class="section-heading">
        <p class="eyebrow">Reservations</p>
        <h2>My Reservations</h2>
      </div>

      <div class="empty-state">
        <p>Book a cozy table and your reservations will appear here.</p>
        <a href="/reservation" class="btn btn-secondary">Create a Reservation</a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
  </footer>

  <%- include('partials/bottom-nav') %>

</body>
</html>