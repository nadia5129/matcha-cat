<!DOCTYPE html>
<html lang="en">
<head>
  <% /*
  ====================================================
  Page: Account
  Description: Reusable site header for branding and navigation.
  ====================================================
  */%>
  <%- include('partials/head', { title: 'Account' }) %>
</head>

<body>
  <%- include('partials/header') %>

  <main class="reservation-page">

    <section class="profile-hero card" style="padding: 32px; margin-bottom: 24px;">
      <div class="profile-copy">
        <p class="eyebrow">My Account</p>
        <h1>Hi, <%= user ? user.first_name : 'Guest' %>!</h1>
        <p>Manage your profile, check past orders, and keep track of your reservations.</p>
      </div>
    </section>

    <section class="form-container" style="margin-bottom: 24px; text-align: center;">
      <% if (user) { %>
        <p class="eyebrow">Member Access</p>
        <h2 class="form-title">Account Settings</h2>
        <p style="margin-bottom: 16px;">You are currently logged in as <strong><%= user.first_name %></strong>.</p>
        <a href="/logout" class="btn-submit" style="display: inline-block; width: auto; padding: 16px 40px; text-decoration: none;">
          Log Out
        </a>
      <% } else { %>
        <p class="eyebrow">New Here?</p>
        <h2 class="form-title">Create an Account</h2>
        <p style="margin-bottom: 20px;">Sign up to save your orders and manage reservations or Log In</p>
        <div style="display: flex; justify-content: center; gap: 12px;">
          <a href="/create-an-account" class="btn-submit" style="display: inline-block; width: auto; padding: 16px 40px; text-decoration: none;">
            Create Account
          </a>
          <a href="/login" class="btn-submit" style="display: inline-block; width: auto; padding: 16px 40px; text-decoration: none;">
            Log In
          </a>
        </div>
      <% } %>
    </section>

    <div class="form-container" style="margin-bottom: 24px;">
      <div class="section-heading">
        <p class="eyebrow">Profile</p>
        <h2 class="form-title">Edit Information</h2>
      </div>

      <form action="/edit-profile" method="POST" class="account-form">
        <div class="input-grid">
          <div class="form-field">
            <label for="fname">First Name</label>
            <input type="text" id="fname" name="fname" placeholder="Enter your first name" value="<%= user ? user.first_name : '' %>" required>
          </div>

          <div class="form-field">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 555-5555" value="<%= user ? user.phone : '' %>" required>
          </div>

          <div class="form-field full-width">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email" value="<%= user ? user.email : '' %>" required>
          </div>
        </div>
        <button type="submit" class="btn-submit">Save Changes</button>
      </form>
    </div>

    <section class="form-container" style="margin-bottom: 24px;">
      <div class="section-heading">
        <p class="eyebrow">Orders</p>
        <h2 class="form-title">Order History</h2>
      </div>

      <% if (orders && orders.length > 0) { %>
        <div class="orders-list">
          <% orders.forEach(order => { %>
            <div class="card" style="padding: 20px; margin-bottom: 16px; border: 1px solid #f4ece4; border-radius: 12px; background-color: #fff;">
              <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #f4ece4; padding-bottom: 8px; margin-bottom: 12px;">
                <span style="font-weight: 700; color: var(--pink-dark);">Order #<%= order.id %></span>
                <span style="font-size: 0.85rem; color: #888;"><%= new Date(order.created_at).toLocaleDateString() %></span>
              </div>
              
              <ul style="list-style: none; padding: 0; margin-bottom: 12px;">
                <% order.items.forEach(item => { %>
                  <li style="font-size: 0.9rem; display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span><%= item.name %> <small style="color: #888;">(<%= item.size %>)</small></span>
                    <span>$<%= parseFloat(item.price).toFixed(2) %></span>
                  </li>
                <% }) %>
              </ul>

              <div style="text-align: right; border-top: 1px dashed #f4ece4; pt: 8px;">
                <p style="font-weight: 800; font-size: 1.1rem; margin: 8px 0 0 0; color: #333;">
                  Total: $<%= parseFloat(order.total).toFixed(2) %>
                </p>
              </div>
            </div>
          <% }) %>
        </div>

      <% } else { %>
        <div class="empty-state">
          <p>Your previous drinks and treats will show up here.</p>
          <a href="/menu" class="btn btn-secondary" style="margin-top: 12px; display: inline-block; text-decoration: none; border: 1px solid #ccc; padding: 8px 16px; border-radius: 4px;">Order Something Sweet</a>
        </div>
      <% } %>
    </section>

    <section class="form-container">
      <div class="section-heading">
        <p class="eyebrow">Reservations</p>
        <h2 class="form-title">My Reservations</h2>
      </div>

      <% if (reservations && reservations.length > 0) { %>
        <div class="reservations-list">
          <% reservations.forEach(r => { %>
            <div class="card" style="padding: 20px; margin-bottom: 16px; border: 1px solid #eee; border-radius: 8px;">
              <p><strong>Date:</strong> <%= new Date(r.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              <p><strong>Time:</strong> <%= r.time %></p>
              <p><strong>Party Size:</strong> <%= r.size %></p>
              <% if (r.comment) { %>
                <p><strong>Special Requests:</strong> <%= r.comment %></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p>Book a cozy table and your reservations will appear here.</p>
          <a href="/reservation" class="btn btn-secondary" style="margin-top: 12px; display: inline-block; text-decoration: none; border: 1px solid #ccc; padding: 8px 16px; border-radius: 4px;">Create a Reservation</a>
        </div>
      <% } %>
    </section>

  </main>

  <%- include('partials/footer') %>
  <%- include('partials/bottom-nav') %>

</body>
</html>