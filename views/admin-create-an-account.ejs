<!DOCTYPE html>
<html lang="en">
<head>
    <%--
    ====================================================
    Page: Admin – Account Submissions
  
    Description:
    Administrative dashboard that displays all
    submitted account/profile form data.

    Data is dynamically rendered from the database
    using EJS templating. The table is enhanced
    with the DataTables library for sorting,
    searching, and responsive behavior.
    ====================================================
    --%>

     <!-- Reusable Head Partial -->
    <%- include('partials/head', { title: 'Admin – Account Submissions' }) %>

    <!-- DataTables & jQuery Libraries -->
    <!-- jQuery required for DataTables functionality -->
    <script src="//code.jquery.com/jquery-3.7.1.js"></script>

    <!-- DataTables JavaScript -->
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>

    <!-- DataTables Styles -->
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css">
</head>

<body>
    <!-- Site Header -->
    <header class="site-header">
        <img src="/images/logo.jpg">
    </header>

    <!-- Page Title -->
    <h1>Account Submissions</h1>

    <!-- Account Submissions Table -->
    <!-- This table displays user-submitted profile data -->
    <table id="account-table" class="display">
         <!-- Table Column Headers -->
        <thead>
            <tr>
                <th>Username</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Phone</th>
                <th>Birthday</th>
                <th>Email</th>
                <th>Timestamp</th>
            </tr>
        </thead>

         <!-- Dynamically Rendered Table Data -->
        <tbody>
            <% submissions.forEach(submission => { %>
                <tr>
                    <td><%= submission.username %></td>
                    <td><%= submission.firstName %></td>
                    <td><%= submission.lastName %></td>
                    <td><%= submission.phone %></td>
                    <td><%= submission.birthday %></td>
                    <td><%= submission.email %></td>
                    <td><%= submission.timestamp %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <!--footer-->
    <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
    </footer>

    <!-- Reusable Bottom Navigation -->
    <%- include('partials/bottom-nav') %>

    <!-- Initialize DataTables-->
    <script>
        let table = new DataTable('#account-table', { responsive: true });
    </script>
    
</body>
</html>