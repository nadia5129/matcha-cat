<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/head', { title: 'Admin – Account Submissions' }) %>

     <!-- Scripts -->
    <script src="//code.jquery.com/jquery-3.7.1.js"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>
    <!-- Styles -->
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css">
</head>
<body>
    <!--header-->
    <header class="site-header">
        <img src="/images/logo.jpg">
    </header>

    <h1>Account Submissions</h1>

    <table id="account-table" class="display">
        <thead>
            <tr>
                <th>Username</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Phone</th>
                <th>Birthday</th>
                <th>Email</th>
                <th>Timestamp</th>
            </tr>
        </thead>
        <tbody>
            <% submissions.forEach(submission => { %>
                <tr>
                    <td><%= submission.username %></td>
                    <td><%= submission.firstName %></td>
                    <td><%= submission.lastName %></td>
                    <td><%= submission.phone %></td>
                    <td><%= submission.birthday %></td>
                    <td><%= submission.email %></td>
                    <td><%= submission.timestamp %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <!--footer-->
    <footer class="site-footer">
        <p>Matcha Cat Cafe • Seattle, WA</p>
    </footer>
    <%- include('partials/bottom-nav') %>
    <!-- script  -->
    <script>
        let table = new DataTable('#account-table', { responsive: true });
    </script>
    
</body>
</html>