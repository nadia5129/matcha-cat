<!DOCTYPE html>
<html lang="en">
<head>
    <%--
    ====================================================
    Page: Admin – Order History

    Description:
    Administrative dashboard displaying all
    submitted customer orders in real time.

    Orders are dynamically rendered from the server.
    The DataTables library enhances the table with:
    - Sorting
    - Pagination
    - Search functionality
    - Responsive behavior

    The order items column handles nested item arrays.
    ====================================================
    --%>

    <!-- Reusable Head Partial -->
    <%- include('partials/head', { title: 'Admin - Order History' }) %>
     <!-- DataTables Styles -->
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css">
</head>

<body>
<main class="admin-container">
    <!-- Page Heading -->
    <h2>Live Order Feed 🍵</h2>

    <!-- Responsive Table Wrapper -->
    <div class="table-responsive">

        <!-- Orders Table -->
        <table id="ordersTable" class="display" style="width:100%">
            <!-- Table Column Headers -->
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Total</th>
                </tr>
            </thead>

            <!-- Dynamically Rendered Order Data -->
            <tbody>
                <% orders.forEach(order => { %>
                <tr>
                    <td><%= order.timestamp %></td>
                    <td><%= order.customerName %></td>
                    <td>
                        <ul class="admin-item-list">
                            <% if (order.items && Array.isArray(order.items)) { %>
                                <% order.items.forEach(item => { %>
                                    <li><%= item.name %> (<%= item.size %>)</li>
                                <% }) %>
                            <% } else { %>
                                <li>No item data</li>
                            <% } %>
                        </ul>
                    </td>
                    <td>$<%= order.total %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</main>

<!-- jQuery (Required for DataTables) -->
<script src="//code.jquery.com/jquery-3.7.1.js"></script>
<!-- DataTables JavaScript -->
<script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>

<!-- Initialize DataTables -->
<script>
    $(document).ready(function() {
        $('#ordersTable').DataTable({
            "order": [[ 0, "desc" ]], // Sort by the first column (Time) descending
            "pageLength": 10
        });
    });
</script>

<!-- Footer -->
<%- include('partials/footer') %>

</body>
</html>