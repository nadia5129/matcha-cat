<!DOCTYPE html>
<html lang="en">
<head>
    <!--
    ====================================================
    Page: Admin – Reservation Submissions
  
    Description:
    Administrative page that displays all reservation
    submissions made by users.

    Reservation data is dynamically rendered from the
    server using EJS. The DataTables library is used
    to improve the table with sorting, searching,
    and interactive display features.
    ====================================================
    -->

    <!-- Reusable Head Partial -->
    <%- include('partials/head', { title: 'Admin - Reservations' }) %>

    <!-- jQuery Library (required for some DataTables setups) -->
    <script src="//code.jquery.com/jquery-3.7.1.js"></script>

    <!-- DataTables JavaScript -->
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>

    <!-- DataTables Styles -->
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css">
</head>

<body>

    <!-- Page Title -->
    <h1>Reservation Submissions</h1>

    <!-- Reservations Table -->
    <table id="reservations-table">

        <!-- Table Headers -->
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Date</th>
                <th>Time</th>
                <th>Party Size</th>
                <th>Comment</th>
                <th>Timestamp</th>
            </tr>
        </thead>

        <!-- Dynamically Rendered Reservation Data -->
        <tbody>

            <%-- Loop through reservation submissions from the server --%>
            <% submissions.forEach(r => { %>
            <tr>
                <td><%= r.fname %></td>
                <td><%= r.phone %></td>
                <td><%= r.email %></td>
                <td><%= r.date %></td>
                <td><%= r.time %></td>
                <td><%= r.size %></td>
                <td><%= r.comment %></td>
                <td><%= r.timestamp %></td>
            </tr>
            <% }) %>

        </tbody>
    </table>

    <!-- Initialize DataTables for interactive table features -->
    <script>
        /*
        Adds DataTables functionality to the reservations table.
        This provides sorting, searching, and a cleaner admin view.
        */
        new DataTable('#reservations-table');
    </script>

    <!-- Site Footer -->
   <%- include('partials/footer') %>

    <!-- Reusable Bottom Navigation -->
    <%- include('partials/bottom-nav') %>

</body>
</html>