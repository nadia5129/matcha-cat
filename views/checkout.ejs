<%- include('partials/head.ejs') %>

<main class="reservation-page">
  <div class="page-intro">
    <h1>Checkout</h1>
    <p>Review your order and complete your payment below.</p>
  </div>

  <div class="form-container order-summary-section">
    <h2 class="form-title">Order Summary</h2>
    <div class="review-order-header">
      <a href="/review" class="edit-link">Edit Order</a>
    </div>

    <div class="checkout-item-list">
      <% if (order && order.length > 0) { %>
        <% order.forEach(item => { %>
          <div class="checkout-item">
            <div class="checkout-item-info">
              <span class="item-name"><strong><%= item.name %></strong></span>
              <br>
              <small class="item-meta"><%= item.size %> | <%= item.milk %></small>
            </div>
            <span class="item-price"><%= item.price %></span>
          </div>
        <% }); %>

        <div class="order-total">
          <p class="total-row">
            <span>Total (<%= order.length %> items):</span>
            <span class="total-amount">$<%= total %></span>
          </p>
          <% if (user || (locals.previousData && previousData.student === 'on')) { %>
            <p class="discount-tag">
              ✓ 5% Student Discount Applied
            </p>
          <% } %>
        </div>

      <% } else { %>
        <p>Your cart is empty. <a href="/menu">Go to Menu</a></p>
      <% } %>
    </div>
  </div>

  <div class="form-container">
    <h2 class="form-title">Payment Information</h2>

    <% if (locals.errors && errors.length > 0) { %>
      <div class="error-banner">
        <p class="error-banner-title">Please check the following:</p>
        <ul class="error-list">
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/place-order" method="POST" class="checkout-form">
      <div class="input-grid">
        
        <div class="form-field full-width">
          <label for="card-number">Card Number</label>
          <input type="text" id="card-number" name="cardNumber" maxlength="19" placeholder="0000 0000 0000 0000" 
                 value="<%= locals.previousData ? previousData.cardNumber : '' %>" required>
        </div>

        <div class="form-field">
          <label for="expirationDate">Expiration Date</label>
          <input type="text" id="expirationDate" name="expirationDate" placeholder="MM/YY" maxlength="5" 
                 value="<%= locals.previousData ? previousData.expirationDate : '' %>" required>
        </div>

        <div class="form-field">
          <label for="cvc">CVC</label>
          <input type="text" id="cvc" name="cvc" placeholder="123" maxlength="4" 
                 value="<%= locals.previousData ? previousData.cvc : '' %>" required>
        </div>

        <div class="form-field full-width">
          <label for="nameOnCard">Name on Card</label>
          <input type="text" id="nameOnCard" name="nameOnCard" 
                 value="<%= locals.previousData ? previousData.nameOnCard : (user ? user.first_name + ' ' + user.last_name : '') %>" required>
        </div>

        <div class="form-field">
          <label for="email">Email for Receipt</label>
          <input type="email" id="email" name="email" 
                 value="<%= locals.previousData ? previousData.email : (user ? user.email : '') %>" required>
        </div>

        <div class="form-field">
          <label for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" 
                 value="<%= locals.previousData ? previousData.phone : (user ? user.phone : '') %>" required>
        </div>
      </div>

      <div class="discount-selection-box">
        <label class="checkbox-label">
          <input type="checkbox" name="student" <%= (user || (locals.previousData && previousData.student === 'on')) ? 'checked' : '' %>>
          <span>Apply Student Discount (5% off - in store only)</span>
        </label>
      </div>

      <% if (locals.drinkCount >= 3) { %>
        <div class="free-pastry-selection">
          <label for="freePastry">
            <strong>✨ Buy 3 Drinks Reward: Choose your FREE pastry!</strong>
          </label>
          <select name="freePastry" id="freePastry" class="pastry-dropdown">
            <option value="Butter Croissant">Butter Croissant</option>
            <option value="Chocolate Croissant">Chocolate Croissant</option>
            <option value="Almond Danish">Almond Danish</option>
            <option value="Strawberry Roll">Strawberry Roll</option>
            <option value="Matcha Muffin">Matcha Muffin</option>
            <option value="Cat Paw Cookie">Cat Paw Cookie</option>
          </select>
        </div>
      <% } %>

      <div class="order-type-selection">
        <label class="selection-title">Order Type:</label>
        <div class="radio-group">
          <label><input type="radio" name="orderType" value="online" checked> Online</label>
          <label><input type="radio" name="orderType" value="in-store"> In Store</label>
          <label><input type="radio" name="orderType" value="takeout"> Takeout</label>
        </div>
      </div>

      <button type="submit" class="btn-submit">Place Order</button>
    </form>
  </div>
</main>

<%- include('partials/bottom-nav.ejs') %>
<%- include('partials/footer.ejs') %>