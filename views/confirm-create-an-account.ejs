<!DOCTYPE html>
<html lang="en">
<head>
    <%/*
    ====================================================
    Page: Account Created Confirmation
  
    Description:
    Displays confirmation details after a user
    successfully creates an account.

    If submission data exists, the page renders
    the user’s account information. If no data
    is found, a fallback message is displayed.
    ====================================================
    */ %>

    <%- include('partials/head', { title: 'Account Created' }) %>
</head>

<body>
    
<!-- Partial For Site Header / Brand Logo -->
<%- include('partials/header') %>

    <!-- Account Creation Confirmation Section -->
    <main>
        <section id="confirm-create-an-account-section" class="confirm-section">

            <%-- Check if submission data was passed from the server --%>
            <% if (submission) { %>

                <!-- Success Message -->
                <h2>Account Created! MEOW</h2>
                <p>
                    Welcome, 
                    <strong><%= submission.firstName %> <%= submission.lastName %></strong>!
                </p>

                <!-- Display Submitted Account Details -->
                <div class="confirm-details">
                    <ul>
                        <li><strong>Username:</strong> <%= submission.username %></li>
                        <li><strong>Name:</strong> <%= submission.firstName %> <%= submission.lastName %></li>
                        <li><strong>Phone:</strong> <%= submission.phone %></li>
                        <li><strong>Birthday:</strong> <%= submission.birthday %></li>
                        <li><strong>Email:</strong> <%= submission.email %></li>
                        <li><strong>Submitted:</strong> <%= submission.timestamp %></li>
                    </ul>
                </div>

                <!-- Navigation Back to Home -->
                <a href="/">Back to Home</a>

            <% } else { %>

                <!-- Fallback Message if No Submission Data Exists -->
                <h2>No account data found.</h2>
                <a href="/create-account">Create an Account</a>

            <% } %>

        </section>
    </main>

    <!-- Site Footer -->
   <%- include('partials/footer') %>

    <!-- Reusable Bottom Navigation -->
    <%- include('partials/bottom-nav') %>

</body>
</html>