<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Order Confirmed' }) %>
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo-text">
  <span class="matcha">Matcha</span> <span class="cat">Cat</span>
</a>
  </header>

  <main class="confirmation-container" style="text-align: center; padding: 50px 20px;">
    <div class="success-icon" style="font-size: 4rem;">🐾</div>
    <h1>Thank you, <%= orderDetails.customerName %>!</h1>
    <p>Your order has been placed and a receipt was sent to <strong><%= orderDetails.email %></strong>.</p>
    
    <div class="order-number" style="margin: 20px 0; color: #88ab75; font-weight: bold;">
        Order #<%= Math.floor(Math.random() * 1000000) %>
    </div>

    <a href="/menu" class="add-btn" style="text-decoration: none; padding: 15px 30px; display: inline-block;">Back to Menu</a>
  </main>

  <%- include('partials/bottom-nav') %>
</body>
</html>