<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Create Account' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>
<body>

  <!--header-->
  <header class="site-header">
    <img src="/images/logo.jpg">
  </header>
  <!--create an account section -->
  <main>
    <section id="create-an-account-section" class="form-section">
      <h2>Create an Account</h2>
      <form id="create-an-account-form" class="account-form" action="/submit" method="POST" novalidate>

        <div class="form-field">
          <label for="username">Username:</label>
          <input type="text" id="username" name="username" required>
          <span id="username-error" class="error-message"></span>
        </div>

        <div class="form-field">
          <label for="first-name">First Name:</label>
          <input type="text" id="first-name" name="fname" required>
          <span id="first-name-error" class="error-message"></span>
        </div>

        <div class="form-field">
          <label for="last-name">Last Name:</label>
          <input type="text" id="last-name" name="lname" required>
          <span id="last-name-error" class="error-message"></span>
        </div>

        <div class="form-field">
          <label for="phone">Phone Number:</label>
          <input type="tel" id="phone" name="phone" required>
          <span id="phone-error" class="error-message"></span>
        </div>

        <div class="form-field">
          <label for="birthday">Birthday:</label>
          <input type="date" id="birthday" name="birthday" required>
          <span id="birthday-error" class="error-message"></span>
        </div>

        <div class="form-field">
          <label for="email">Email:</label>
          <input type="email" id="email" name="email" required>
          <span id="email-error" class="error-message"></span>
        </div>

        <div class="form-field">
          <label for="password">Password:</label>
          <input type="password" id="password" name="password" required>
          <span id="password-error" class="error-message"></span>
        </div>

        <button type="submit">Create Account</button>
      </form>
    </section>
  </main>

  <!--footer-->
  <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
  </footer>

  <%- include('partials/bottom-nav') %>

</body>
</html>