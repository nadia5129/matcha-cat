<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Home' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>
<body>

  <!--header-->
  <header class="site-header">
    <img src="/images/logo.jpg">
  </header>

  <!-- Hero video OUTSIDE main so it goes full width -->
  <section class="home-video">
    <video autoplay muted loop playsinline>
      <source src="/media/matcha-eating-video.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  </section>

  <main>

    <!--About Section-->
    <section class="about">
      <h1>Welcome to Matcha Cat</h1>
      <p>Women owned and ethically sourced</p>
      <video autoplay muted loop playsinline>
        <source src="/media/136050-764371327_medium.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </section>

    <!--Cat section-->
    <section class="cat-section">
      <div class="cat">
        <!--cat images here-->
        <button onclick="window.location.href='/reservation'">Click here to reserve</button>
      </div>
    </section>

  </main>

  <!--footer-->
  <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
  </footer>

  <%- include('partials/bottom-nav') %>

</body>
</html>