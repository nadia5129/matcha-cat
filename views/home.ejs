<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Home' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>
<body>

  <!--header-->
  <header class="site-header">
    <img src="/images/logo.jpg" alt="Matcha Cat Cafe logo">
  </header>

  <!-- Hero video OUTSIDE main so it goes full width -->
  <section class="home-video">
    <video autoplay muted loop playsinline>
      <source src="/media/matcha-eating-video.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  </section>

  <main>

    <!--About Section-->
    <section class="about">
      <h1>Welcome to Matcha Cat</h1>
      <p>Women owned and ethically sourced</p>
      <video autoplay muted loop playsinline>
        <source src="/media/136050-764371327_medium.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </section>

    <!--Menu Section-->
    <section class="home-section section-beige">
      <h2>Find your perfect drink</h2>
      <p>Explore our menu to find matcha, coffee, pastries, and sweet treats made fresh.</p>

      <div class="feature-actions">
        <a class="btn btn-primary" href="/menu">View Full Menu</a>
      </div>

      <div class="feature-media menu-media">
        <div class="menu-grid-preview">
          <img src="/images/iced-matcha.png" alt="Matcha Latte">
          <img src="/images/iced-latte.png" alt="Matcha Cake">
          <img src="/images/matcha-cake.png" alt="Matcha Smoothie">
        </div>
      </div>
    </section>

    <!--Cat section-->
    <section class="cat-section">
      <h2>Spend time with our cats</h2>
      <p>Reserve a cozy space to relax, sip matcha, and play with our friendly cats.</p>

      <div class="feature-actions">
        <a class="btn btn-secondary" href="/deals">View Deals</a>
        <button class="btn btn-primary" onclick="window.location.href='/reservation'">Click here to reserve</button>
      </div>

      <div class="feature-media cats-media">
        <div class="cat-grid">
          <img src="/images/cat-one.png" alt="Cat at Matcha Cat Cafe">
          <img src="/images/cat-two.png" alt="Cat at Matcha Cat Cafe">
          <img src="/images/cat-three.png" alt="Cat at Matcha Cat Cafe">
          <img src="/images/cat-four.png" alt="Cat at Matcha Cat Cafe">
        </div>
      </div>
    </section>

  </main>

  <!--footer-->
  <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
  </footer>

  <%- include('partials/bottom-nav') %>

</body>
</html>