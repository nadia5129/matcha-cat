<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Menu Item' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>
<body>

  <!--header-->
  <header class="site-header">
    <img src="/images/logo.jpg">
  </header>

  <main>

    <!-- Item Image -->
    <section class="item-hero">
      <div class="item-image-circle">
        <img src="/images/matcha-latte.jpg" alt="Matcha Latte">
      </div>
      <h1 class="item-title">Matcha Latte</h1>
    </section>

    <form action="/add-to-order" method="POST">

      <!-- Size Options -->
      <section class="item-options">
        <h2>Size Option</h2>
        <div class="option-list">
          <label class="option-row">
            <input type="radio" name="size" value="8oz" required>
            <span>8 oz</span>
          </label>
          <label class="option-row">
            <input type="radio" name="size" value="16oz">
            <span>16 oz</span>
          </label>
        </div>
      </section>

      <!-- Milk Options -->
      <section class="item-options">
        <h2>Milk</h2>
        <div class="option-list">
          <label class="option-row">
            <input type="radio" name="milk" value="milk" required>
            <span>Milk</span>
          </label>
          <label class="option-row">
            <input type="radio" name="milk" value="oat-milk">
            <span>Oat Milk</span>
          </label>
          <label class="option-row">
            <input type="radio" name="milk" value="soy">
            <span>Soy</span>
          </label>
          <label class="option-row">
            <input type="radio" name="milk" value="whole-milk">
            <span>Whole Milk</span>
          </label>
        </div>
      </section>

      <!-- Description -->
      <section class="item-description">
        <h2>Description</h2>
        <textarea name="description" rows="3" placeholder="Any special instructions..."></textarea>
      </section>

      <button type="submit" class="add-to-order-btn">Add to Order</button>

    </form>

  </main>

  <!--footer-->
  <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
  </footer>

  <%- include('partials/bottom-nav') %>

</body>
</html>