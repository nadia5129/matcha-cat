<!DOCTYPE html>
<html lang="en">
<head>
  <%
  /*
  ====================================================
  Page: Menu
  Author: Paris

  Description:
  Displays all available menu items categorized
  into Coffee, Matcha, and Pastries.

  Users can switch between categories using
  tab navigation. Menu items are dynamically
  generated from the server-side "menu" object.
  ====================================================
  */
  %>

  <!-- Reusable head partial -->
  <%- include('partials/head', { title: 'Menu' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>
<body>

  <!-- Partial For Site Header / Brand Logo -->
  <%- include('partials/header') %>

  <main class="menu-page">

    <nav class="menu-tabs">
      <button class="tab active" onclick="showCategory('coffee', event)">Coffee</button>
      <button class="tab" onclick="showCategory('matcha', event)">Matcha</button>
      <button class="tab" onclick="showCategory('pastries', event)">Pastries</button>
    </nav>

    <section id="coffee" class="menu-category">
      <h2>Coffee</h2>
      <div class="menu-grid">
        <% Object.keys(menu).forEach(key => { %>
          <% if (menu[key].category === 'coffee') { %>
            <div class="menu-item">
              <img src="/images/<%= menu[key].image %>" alt="<%= menu[key].name %>">
              <div class="item-info">
                <p class="item-name"><%= menu[key].name %></p>
                <p class="item-description"><%= menu[key].description %></p>
                <p class="item-price"><%= menu[key].price %></p>
              </div>
              <a href="/menu-item/<%= key %>" class="btn add-btn">View</a>
            </div>
          <% } %>
        <% }); %>
      </div>
    </section>

    <section id="matcha" class="menu-category hidden">
      <h2>Matcha</h2>
      <div class="menu-grid">
        <% Object.keys(menu).forEach(key => { %>
          <% if (menu[key].category === 'matcha') { %>
            <div class="menu-item">
              <img src="/images/<%= menu[key].image %>" alt="<%= menu[key].name %>">
              <div class="item-info">
                <p class="item-name"><%= menu[key].name %></p>
                <p class="item-description"><%= menu[key].description %></p>
                <p class="item-price"><%= menu[key].price %></p>
              </div>
              <a href="/menu-item/<%= key %>" class="btn add-btn">View</a>
            </div>
          <% } %>
        <% }); %>
      </div>
    </section>

    <section id="pastries" class="menu-category hidden">
      <h2>Pastries</h2>
      <div class="menu-grid">
        <% Object.keys(menu).forEach(key => { %>
          <% if (menu[key].category === 'pastries') { %>
            <div class="menu-item">
              <img src="/images/<%= menu[key].image %>" alt="<%= menu[key].name %>">
              <div class="item-info">
                <p class="item-name"><%= menu[key].name %></p>
                <p class="item-description"><%= menu[key].description %></p>
                <p class="item-price"><%= menu[key].price %></p>
              </div>
              <a href="/menu-item/<%= key %>" class="btn add-btn">View</a>
            </div>
          <% } %>
        <% }); %>
      </div>
    </section>

    <div class="view-order">
      <a href="/review"><button>View Order 🛍️</button></a>
    </div>

  </main>

  <!-- Reusable Footer -->
  <%- include('partials/footer') %>

  <!-- Reusable Bottom Navigation -->
  <%- include('partials/bottom-nav') %>

</body>
</html>