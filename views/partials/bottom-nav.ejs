<%/*
Component: Bottom Navigation Bar

Description:
Reusable bottom navigation component displayed
across all primary pages of the application.
Provides quick access to Home, Menu (Order),
Checkout, Deals and Account pages.

This component uses Lucide icons for visual
navigation indicators.
*/%>

<nav class="bottom-nav">
  <a href="/" class="nav-item">
    <i data-lucide="home" class="nav-icon"></i>
    <span class="nav-label">Home</span>
  </a>

  <a href="/menu" class="nav-item">
    <i data-lucide="coffee" class="nav-icon"></i>
    <span class="nav-label">Order</span>
  </a>

  <a href="/checkout" class="nav-item">
    <i data-lucide="credit-card" class="nav-icon"></i>
    <span class="nav-label">Checkout</span>
  </a>

  <a href="/deals" class="nav-item">
    <i data-lucide="tag" class="nav-icon"></i>
    <span class="nav-label">Deals</span>
  </a>

  <a href="/account" class="nav-item">
    <i data-lucide="user" class="nav-icon"></i>
    <span class="nav-label">Account</span>
  </a>
</nav>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
  lucide.createIcons();
</script>
