<%/*
Component: Head Section

Description:
Reusable head partial included on all pages.
Defines metadata, page title, global stylesheet,
favicon, and shared JavaScript file.

Ensures consistent styling and responsive behavior
across the entire application.
*/%>

<!-- Character Encoding -->
<meta charset="UTF-8">

<!-- Responsive Mobile Viewport -->
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Page Title -->
<title>Matcha Cat Café</title>

<!-- Global Stylesheet -->
<link rel="stylesheet" href="/css/style.css">

<!-- Favicon (Browser Tab Icon) -->
<link rel="icon" href="/images/matcha-cat.jpg" type="image/x-icon">

<!-- Global JavaScript File (Deferred for Performance) -->
<script defer src="/js/matcha-cat.js"></script>

