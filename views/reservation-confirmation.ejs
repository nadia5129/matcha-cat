<!DOCTYPE html>
<html lang="en">
<head>
  <%
  /*
  ====================================================
  Page: Reservation Summary
  Author: Nadia Ivanishchuk
  
  Description:
  Displays a confirmation summary after a user
  successfully submits a reservation form.

  This page dynamically renders reservation details
  passed from the server, including name, date,
  time, party size, contact information, and
  optional special comments.
  ====================================================
  */
  %>

  <!-- Reusable Head Partial -->
  <%- include('partials/head', { title: 'Reservation Summary' }) %>
</head>

<body>
  <!-- Partial For Site Header / Brand Logo -->
  <%- include('partials/header') %>

<main>
  <!-- Main Reservation Confirmation Content -->
  <section class="reservation-section">
    <h1>Reservation Summary </h1>

    <!-- Dynamic thank-you message using submitted first name -->
    <p>Thanks, <%= reservation.fname %>! Your reservation has been saved.</p>
  </section>

  <!-- Reservation Details Card -->
  <section class="res-form">
    <div class="card">
      <p><strong>Date:</strong> <%= reservation.date %></p>
      <p><strong>Time:</strong> <%= reservation.time %></p>
      <p><strong>Party Size:</strong> <%= reservation.size %></p>
      <p><strong>Phone:</strong> <%= reservation.phone %></p>
      <p><strong>Email:</strong> <%= reservation.email %></p>

      <% if (reservation.comment && reservation.comment.trim().length > 0) { %>
        <p><strong>Comments:</strong> <%= reservation.comment %></p>
      <% } %>

      <!-- Timestamp generated on server -->
      <p><strong>Submitted:</strong> <%= reservation.timestamp %></p>
    </div>

 <!-- Button to create another reservation -->
  <div style="margin-top: 16px;">
  <button class="confirm-res-btn" type="button" onclick="window.location.href='/reservation'">
    Make another reservation
  </button>
</div>
  </section>
</main>

 <!-- Reusable Footer -->
  <%- include('partials/footer') %>

  <!-- Reusable Bottom Navigation -->
  <%- include('partials/bottom-nav') %>

</body>
</html>