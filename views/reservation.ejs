<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Reservation' }) %>
  <script defer src="/js/matcha-cat.js"></script>
</head>
<body>

  <!--header-->
  <header class="site-header">
    <img src="/images/logo.jpg">
  </header>

  <main>
    <section class="reservation-section">
      <h1>Reservations</h1>
    </section>

    <section class="res-form">
      <form id="reservation-form" action="/reserve" method="POST">
        <fieldset>
          <legend>Reserve a Visit</legend>

          <div class="form-field">
            <label for="fname">First Name</label>
            <input type="text" id="fname" name="fname">
            <span id="fname-error" class="error-message"></span>
          </div>

          <div class="form-field">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone">
            <span id="phone-error" class="error-message"></span>
          </div>

          <div class="form-field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email">
            <span id="email-error" class="error-message"></span>
          </div>

          <div class="form-field">
            <label for="date">Select a Date</label>
            <input type="date" id="date" name="date">
            <span id="date-error" class="error-message"></span>
          </div>

          <div class="form-field">
            <label for="time">Select a Time</label>
            <input type="time" id="time" name="time">
            <span id="time-error" class="error-message"></span>
          </div>

          <div class="form-field">
            <label for="size">Select Party Size</label>
            <select id="size" name="size">
              <option value="">-- Select --</option>
              <option value="1">1 person</option>
              <option value="2">2 people</option>
              <option value="3">3 people</option>
              <option value="4">4 people</option>
              <option value="5+">5+ people</option>
            </select>
            <span id="size-error" class="error-message"></span>
          </div>

          <div class="form-field">
            <label for="comment">Additional Comments</label>
            <textarea id="comment" name="comment" rows="4"></textarea>
          </div>

          <button type="submit">Reserve</button>

        </fieldset>
      </form>
    </section>
  </main>

  <!--footer-->
  <footer class="site-footer">
    <p>Matcha Cat Cafe • Seattle, WA</p>
  </footer>

  <%- include('partials/bottom-nav') %>

</body>
</html>